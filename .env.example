# ==============================================================================
# StockTrader Backend — Environment Variables
# ==============================================================================
# Copy to .env in the repo root and fill in your values.
# Only SECRET_KEY is required for boot; everything else has safe defaults.

# -- General --
APP_ENV=development          # development | staging | production
SECRET_KEY=change-me         # HMAC / JWT signing key (REQUIRED in prod)
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
PAPER_MODE=true              # true = paper trading only, false = live orders
PORT=8000                    # HTTP port (Fly.io sets this automatically)

# -- Database --
DATABASE_URL=sqlite:///./stocktrader.db   # or postgresql://user:pass@host/db

# -- Redis / Celery (optional — app boots without them) --
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -- CORS --
ALLOWED_ORIGINS=*            # comma-separated, e.g. https://myapp.vercel.app,http://localhost:4200
VERCEL_URL=                  # auto-populated by Vercel; adds to CORS origins

# -- ML / Models --
MODEL_REGISTRY_PATH=models/registry.json
STORAGE_PATH=storage
MLFLOW_TRACKING_URI=         # leave empty to use local JSON registry

# -- Monitoring (optional) --
SENTRY_DSN=

# -- AngelOne SmartAPI (optional — falls back to CSV replay without these) --
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=
