  "panels": [
    {
      "title": "Prediction Requests / min",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(stocktrader_prediction_requests_total[1m])",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Prediction Latency (p95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(stocktrader_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Model Accuracy",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "stocktrader_model_accuracy",
          "legendFormat": "accuracy"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 }
    },
    {
      "title": "Trade Executions / min",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(stocktrader_trade_executions_total[1m])",
          "legendFormat": "{{side}} {{status}}"
        }
      ],
